// ==========================================
//           BLYNK VIRTUAL PINS
// ==========================================

// V0 — OFF button (push, min 0 max 1)
BLYNK_WRITE(V0) {
  if (param.asInt() == 1) {
    Serial.println(">>> BLYNK: OFF");
    IrSender.sendRaw(rawOff, sizeof(rawOff) / sizeof(rawOff[0]), kFrequency);
  }
}

// V1 — 20°C ON button (push, min 0 max 1)
BLYNK_WRITE(V1) {
  if (param.asInt() == 1) {
    Serial.println(">>> BLYNK: ON 20C");
    IrSender.sendRaw(rawOn20, sizeof(rawOn20) / sizeof(rawOn20[0]), kFrequency);
  }
}

// V2 — 24°C ON button (push, min 0 max 1)
BLYNK_WRITE(V2) {
  if (param.asInt() == 1) {
    Serial.println(">>> BLYNK: ON 24C");
    IrSender.sendRaw(rawOn24, sizeof(rawOn24) / sizeof(rawOn24[0]), kFrequency);
  }
}

// ==========================================
void setup() {
  Serial.begin(115200);
  IrSender.begin(IR_SEND_PIN);
  Serial.println("Connecting to Blynk...");
  Blynk.begin(auth, ssid, pass);
  Serial.println("Blynk Connected!");
}

void loop() {
  Blynk.run();
}
